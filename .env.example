# ── Обязательно ────────────────────────────────────────────────────────────────
# Токен бота Тваштар от @BotFather в Telegram
TVASHTAR_BOT_TOKEN=

# Твой Telegram ID. Узнай у @userinfobot в Telegram.
ALLOWED_CHAT_ID=

# ── Config directory ───────────────────────────────────────────────────────────
# Персональные конфиги (CLAUDE.md, настройки) хранятся здесь, вне репозитория.
# По умолчанию ~/.claudeclaw
# CLAUDECLAW_CONFIG=~/.claudeclaw

# ── Claude Auth (опционально) ─────────────────────────────────────────────────
# ClaudeClaw использует твою авторизацию Claude Code (claude login) по умолчанию.
# Установи ANTHROPIC_API_KEY для оплаты по токенам - рекомендуется для серверов.
ANTHROPIC_API_KEY=

# ── Голос (опционально) ───────────────────────────────────────────────────────
# Groq - бесплатный tier, для транскрипции голосовых (Whisper)
# Получить: https://console.groq.com
GROQ_API_KEY=

# ElevenLabs - генерация голоса
# Получить: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Интеграции (опционально) ──────────────────────────────────────────────────
# Google AI Studio - для анализа видео через Gemini
# Получить: https://aistudio.google.com
GOOGLE_API_KEY=

# OpenAI - для векторной памяти (embeddings)
# Получить: https://platform.openai.com
# Стоимость: ~$0.02 за 1M токенов (практически бесплатно)
OPENAI_API_KEY=

# ── Dashboard (опционально) ───────────────────────────────────────────────────
# Веб-панель для мониторинга памяти, токенов, задач.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DASHBOARD_TOKEN=
# DASHBOARD_PORT=3141

# ── База данных (опционально) ─────────────────────────────────────────────────
# Ключ шифрования SQLite. Генерируется автоматически при первом запуске.
DB_ENCRYPTION_KEY=

# ── Лимиты (опционально) ──────────────────────────────────────────────────────
# Макс. время одного запроса в мс. По умолчанию: 300000 (5 мин).
# AGENT_TIMEOUT_MS=300000

# ── Будущие агенты ────────────────────────────────────────────────────────────
# Когда добавишь новых агентов - их токены сюда:
# INDRA_BOT_TOKEN=
# MANAS_BOT_TOKEN=
# KAMA_BOT_TOKEN=
# DHARMA_BOT_TOKEN=

# ── Slack (опционально) ───────────────────────────────────────────────────────
# SLACK_USER_TOKEN=

# ── Google OAuth (для Gmail + Calendar скиллов) ───────────────────────────────
# GOOGLE_CREDS_PATH=~/.config/gmail/credentials.json
# GMAIL_TOKEN_PATH=~/.config/gmail/token.json
# GCAL_TOKEN_PATH=~/.config/calendar/token.json
